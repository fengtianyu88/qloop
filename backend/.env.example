APP_NAME=qloop
APP_SHORT_NAME=qloop

# 数据库
DATABASE_URL=postgresql+asyncpg://qloop:qloop@localhost:5432/qloop

# Redis(用于 Celery broker / Token 黑名单 / 缓存)
REDIS_URL=redis://localhost:6379/0

# MinIO(对象存储)
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=qloop
MINIO_SECURE=false

# 安全密钥(生产环境必须修改,不能使用默认值)
SECRET_KEY=change-me-in-production

# Token 有效期(分钟)
ACCESS_TOKEN_EXPIRE_MINUTES=480
# Refresh Token 有效期(分钟),默认 7 天
REFRESH_TOKEN_EXPIRE_MINUTES=10080

# 邮件通知(超管可在系统设置中开关)
SMTP_ENABLED=false
SMTP_HOST=smtp.example.com
SMTP_PORT=465
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@qloop.local
SMTP_USE_TLS=true

# LLM 配置
LLM_TIMEOUT=300
LLM_MAX_RETRIES=3
# max_tokens 配置化(按模型类型)
LLM_MAX_TOKENS_OPENAI=8192
LLM_MAX_TOKENS_ANTHROPIC=4096

# 上传文件大小限制(MB)
MAX_UPLOAD_SIZE_MB=200

# CORS 允许的源(逗号分隔)
CORS_ORIGINS=http://localhost:5173,http://localhost

# 日志级别(可选 DEBUG/INFO/WARNING/ERROR/CRITICAL)
LOG_LEVEL=INFO

# 调试模式(生产环境必须为 false,由 validator 强制校验)
DEBUG=false
